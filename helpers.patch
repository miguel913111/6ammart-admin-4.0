+    public static function generate_transaction_id($object)
+    {
+        if ($object && isset($object->id)) {
+            $prefix = strtoupper(substr($object->getTable(), 0, 3));
+            return $prefix . '-' . strtoupper(Str::random(8)) . '-' . $object->id;
+        }
+        return strtoupper(Str::random(12));
+    }
