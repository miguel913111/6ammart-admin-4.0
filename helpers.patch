+    public static function deliverymanLoyaltyPointHistory($deliveryManId, $amount, $transactionType, $pointConversionType, $reference = null)
+    {
+        try {
+            $settings = self::get_business_settings('dm_loyality_point_data');
+            $pointPerAmount = data_get($settings, 'point_per_amount', 0);
+            $amountPerPoint = data_get($settings, 'amount_per_point', 0);
+
+            if ($transactionType == 'earn_on_order_completion' && $pointConversionType == 'credit') {
+                $points = 0;
+                if ($pointPerAmount > 0 && $amountPerPoint > 0) {
+                    $points = ($amount * $pointPerAmount) / $amountPerPoint;
+                }
+                
+                $dm = \App\Models\DeliveryMan::find($deliveryManId);
+                if ($dm) {
+                    $dm->increment('loyalty_point', $points);
+                }
+                
+                return [
+                    'status_code' => 200,
+                    'points' => $points,
+                ];
+            }
+            
+            if ($transactionType == 'converted_to_wallet' && $pointConversionType == 'debit') {
+                $dm = \App\Models\DeliveryMan::find($deliveryManId);
+                if (!$dm) {
+                    return ['status_code' => 403, 'code' => 'deliveryman_not_found', 'message' => translate('messages.deliveryman_not_found')];
+                }
+                
+                if ($dm->loyalty_point < $amount) {
+                    return ['status_code' => 403, 'code' => 'insufficient_points', 'message' => translate('messages.insufficient_points')];
+                }
+                
+                $wallet = \App\Models\DeliveryManWallet::firstOrNew(['delivery_man_id' => $deliveryManId]);
+                $conversionRate = data_get($settings, 'amount_per_point', 1);
+                $walletAmount = $amount * $conversionRate;
+                
+                $dm->decrement('loyalty_point', $amount);
+                $wallet->total_earning += $walletAmount;
+                $wallet->save();
+                
+                return [
+                    'status_code' => 200,
+                    'wallet_amount' => $walletAmount,
+                ];
+            }
+            
+            return ['status_code' => 200];
+        } catch (\Exception $e) {
+            info(["line___{$e->getLine()}", $e->getMessage()]);
+            return ['status_code' => 403, 'code' => 'loyalty_point', 'message' => translate('messages.something_went_wrong')];
+        }
+    }
