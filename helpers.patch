+    public static function getCoordinatesZone($lat, $lng)
+    {
+        try {
+            $point = new Point($lat, $lng, POINT_SRID);
+            $zone = Zone::query()->whereContains('coordinates', $point)->first();
+            return $zone;
+        } catch (\Exception $e) {
+            return null;
+        }
+    }
