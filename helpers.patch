+    public static function formatDeliverymanText($text, $deliveryMan)
+    {
+        if ($text && $deliveryMan) {
+            $text = str_replace("{deliverymanName}", $deliveryMan->f_name . ' ' . $deliveryMan->l_name, $text);
+            $text = str_replace("{deliveryManName}", $deliveryMan->f_name . ' ' . $deliveryMan->l_name, $text);
+            $text = str_replace("{deliverymanPhone}", $deliveryMan->phone ?? '', $text);
+            $text = str_replace("{deliverymanEmail}", $deliveryMan->email ?? '', $text);
+        }
+        return $text;
+    }
