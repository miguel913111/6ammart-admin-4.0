+    /**
+     * Build the rich FCM payload sent to deliverymen when a new order request
+     * arrives. The Flutter overlay expects these fields to render the card.
+     */
+    public static function build_deliveryman_order_request_payload($order): array
+    {
+        // Basic store / customer info
+        $storeName = $order->store?->name ?? translate('Order_Notification');
+        $storeAddress = $order->store?->address ?? '';
+
+        // Delivery address string
+        $deliveryAddress = '';
+        $deliveryLat = null;
+        $deliveryLng = null;
+        $rawDeliveryAddress = $order->delivery_address;
+        if (is_string($rawDeliveryAddress)) {
+            $rawDeliveryAddress = json_decode($rawDeliveryAddress, true);
+        }
+        if (is_array($rawDeliveryAddress) || is_object($rawDeliveryAddress)) {
+            $addr = (array) $rawDeliveryAddress;
+            $deliveryAddress = $addr['address'] ?? '';
+            if (empty($deliveryAddress) && isset($addr['contact_person_name'])) {
+                $deliveryAddress = $addr['contact_person_name'];
+            }
+            $deliveryLat = $addr['latitude'] ?? null;
+            $deliveryLng = $addr['longitude'] ?? null;
+        }
+
+        // Distance: store -> customer (driver location is unknown at push time).
+        $distance = '';
+        $storeLat = $order->store?->latitude;
+        $storeLng = $order->store?->longitude;
+        if ($storeLat && $storeLng && $deliveryLat && $deliveryLng) {
+            $distance = self::haversine_distance_km($storeLat, $storeLng, $deliveryLat, $deliveryLng);
+        }
+
+        // Earning estimate: delivery charge + tips.
+        $earning = ($order->delivery_charge ?? 0) + ($order->dm_tips ?? 0);
+
+        // Item count from order details.
+        $itemCount = 0;
+        if ($order->relationLoaded('details')) {
+            $itemCount = $order->details->sum('quantity') ?: $order->details->count();
+        } elseif (method_exists($order, 'details')) {
+            $itemCount = $order->details()->sum('quantity') ?: $order->details()->count();
+        }
+
+        $payload = [
+            'title' => translate('Order_Notification'),
+            'description' => translate('New order alert, confirm to proceed'),
+            'order_id' => $order->id,
+            'module_id' => $order->module_id,
+            'order_type' => $order->order_type,
+            'zone_id' => $order->zone_id,
+            'image' => '',
+            'type' => 'order_request',
+            'order_status' => $order->order_status,
+            'store_name' => (string) $storeName,
+            'store_address' => (string) $storeAddress,
+            'delivery_address' => (string) $deliveryAddress,
+            'distance' => (string) $distance,
+            'earning' => (string) self::format_currency($earning),
+            'payment_method' => (string) $order->payment_method,
+            'item_count' => (string) $itemCount,
+            'store_lat' => (string) ($storeLat ?? ''),
+            'store_lng' => (string) ($storeLng ?? ''),
+            'delivery_lat' => (string) ($deliveryLat ?? ''),
+            'delivery_lng' => (string) ($deliveryLng ?? ''),
+        ];
+
+        info('BUILD_DELIVERYMAN_ORDER_REQUEST_PAYLOAD: order_id=' . $order->id . ' payload=' . json_encode($payload));
+
+        return $payload;
+    }
+
+    /**
+     * Haversine distance in kilometers between two coordinates.
+     */
+    public static function haversine_distance_km($lat1, $lng1, $lat2, $lng2): string
+    {
+        $earthRadius = 6371;
+        $dLat = deg2rad(floatval($lat2) - floatval($lat1));
+        $dLng = deg2rad(floatval($lng2) - floatval($lng1));
+        $a = sin($dLat / 2) * sin($dLat / 2) +
+            cos(deg2rad(floatval($lat1))) * cos(deg2rad(floatval($lat2))) *
+            sin($dLng / 2) * sin($dLng / 2);
+        $c = 2 * atan2(sqrt($a), sqrt(1 - $a));
+        $distance = $earthRadius * $c;
+        return $distance > 0 ? number_format($distance, 1) : '';
+    }
