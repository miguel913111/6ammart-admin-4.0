+    public static function formatMetaData($data, $old_meta = null)
+    {
+        $meta = [];
+        $old_meta = is_array($old_meta) ? $old_meta : (is_string($old_meta) ? json_decode($old_meta, true) : []);
+        
+        if (isset($data['meta_title'])) {
+            $meta['meta_title'] = $data['meta_title'];
+        }
+        if (isset($data['meta_description'])) {
+            $meta['meta_description'] = $data['meta_description'];
+        }
+        if (isset($data['meta_image'])) {
+            $meta['meta_image'] = $data['meta_image'];
+        }
+        
+        if (is_array($old_meta) && count($old_meta) > 0) {
+            $meta = array_merge($old_meta, $meta);
+        }
+        
+        return $meta;
+    }
