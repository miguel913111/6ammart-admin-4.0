+    public static function setZoneIds($request)
+    {
+        try {
+            $zone_id = $request->header('zoneId');
+            if (!$zone_id && $request->latitude && $request->longitude) {
+                $point = new Point($request->latitude, $request->longitude, POINT_SRID);
+                $zone = Zone::query()->whereContains('coordinates', $point)->first();
+                if ($zone) {
+                    $zone_id = $zone->id;
+                }
+            }
+            
+            if ($zone_id) {
+                $request->headers->set('zoneId', $zone_id);
+            }
+        } catch (\Exception $e) {
+            info(["setZoneIds_error", $e->getMessage()]);
+        }
+    }
