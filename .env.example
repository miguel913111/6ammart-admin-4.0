APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:/NC6CNBiDJb2vV4fRviEsMqy5gKbePRgk44JGkZFAYY=
APP_DEBUG=true
APP_URL=http://localhost
APP_MODE=dev

# The single hostname where the admin/vendor panel + all host routes live.
# Sub-domains and custom domains in tenant_domain_configs serve the
# storefront at root. Leave both unset for single-tenant / legacy installs.
APP_HOST_DOMAIN=
APP_HOST_BASE_DOMAIN=
APP_PUBLIC_IP=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=multi_food_db
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=database
QUEUE_CONNECTION=database
SESSION_DRIVER=file

# Ryft Payment (https://ryftpay.com)
RYFT_PUBLIC_KEY=
RYFT_SECRET_KEY=
RYFT_WEBHOOK_SECRET=
RYFT_BASE_URL=https://api.ryftpay.com
RYFT_MOCK_MODE=true

# MangoPay (https://mangopay.com)
MANGOPAY_CLIENT_ID=
MANGOPAY_API_KEY=
MANGOPAY_BASE_URL=https://api.sandbox.mangopay.com
MANGOPAY_WEBHOOK_SECRET=
MANGOPAY_MOCK_MODE=true

# Stripe Connect (https://stripe.com/connect)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_MOCK_MODE=true

# InvoiceXpress (https://invoicexpress.com)
INVOICEXPRESS_ACCOUNT_NAME=
INVOICEXPRESS_API_KEY=
INVOICEXPRESS_BASE_URL=
INVOICEXPRESS_MOCK_MODE=true

# Platform fees
PLATFORM_FEE_6AMMART=0.50
PLATFORM_FEE_DRIVEMOND=0.15
PLATFORM_FEE_VAT_RATE=0.23

# Active split-payment gateway: stripe_connect, ryft, mangopay, eupago
PAYMENT_GATEWAY_DEFAULT=stripe_connect

# EuPago (https://eupago.pt)
EUPAGO_ENV=sandbox
EUPAGO_API_KEY=
EUPAGO_CLIENT_ID=
EUPAGO_CLIENT_SECRET=
EUPAGO_WEBHOOK_SECRET=
EUPAGO_STORE_EXTERN_KEY=
EUPAGO_DELIVERY_EXTERN_KEY=
EUPAGO_PLATFORM_EXTERN_KEY=
EUPAGO_MOCK_MODE=true

SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

REVERB_APP_ID=6ammart
REVERB_APP_KEY=6ammart
REVERB_APP_SECRET=6ammart
REVERB_HOST="${APP_URL}"
REVERB_PORT=6001
REVERB_SCHEME=http

PUSHER_APP_ID=6ammart
PUSHER_APP_KEY=6ammart
PUSHER_APP_SECRET=6ammart
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST="${APP_URL}"
PUSHER_PORT=6001
PUSHER_SCHEME=http

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
SOFTWARE_VERSION=3.9
