{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "preDeployCommand": ["sh -c '[ -L public/storage ] || php artisan storage:link'", "php artisan migrate --force"],
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT"
  }
}
